{
  "onEnterRules": [
    {
      "beforeText": "^#SBATCH.+$",
      "action": {
        "indent": "none",
        "appendText": "#SBATCH "
      }
    }
  ],
  "wordPattern": "(-{1,2}\\w[\\w\\-]*)|(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
