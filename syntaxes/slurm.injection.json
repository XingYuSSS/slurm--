{
  "scopeName": "slurm.injection.shell",
  "injectionSelector": "L:source.shell",
  "patterns": [
    {
      "begin": "^#SBATCH(?=\\s|--|-|$)",
      "end": "\\n",
      "name": "meta.slurm.injection",
      "beginCaptures": {
        "0": {
          "name": "keyword.control.slurm"
        }
      },
      "patterns": [
        {
          "include": "#option-long"
        },
        {
          "include": "#option-short"
        },
        {
          "include": "#comment"
        }
      ]
    }
  ],
  "repository": {
    "option-long": {
      "begin": "(--[a-zA-Z][a-zA-Z0-9_-]*)((=)|(?=\\s|$|[#\\n]))",
      "end": "(?=#|\\s+(?:--|-|#|\\n)|$)",
      "name": "meta.option.long.slurm.injection",
      "beginCaptures": {
        "1": {
          "name": "keyword.option.long.slurm.injection"
        },
        "2": {
          "name": "punctuation.separator.equals.slurm.injection"
        }
      },
      "patterns": [
        {
          "include": "#value-content"
        }
      ]
    },
    "option-short": {
      "begin": "(-[a-zA-Z])",
      "end": "(?=#|\\s+(?:--|-|#|\\n)|$)",
      "name": "meta.option.short.slurm.injection",
      "beginCaptures": {
        "1": {
          "name": "keyword.option.short.slurm.injection"
        }
      },
      "patterns": [
        {
          "include": "#value-content"
        }
      ]
    },
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.slurm.injection"
    },
    "escape-sequence": {
      "match": "\\\\.",
      "name": "constant.character.escape.slurm.injection"
    },
    "quoted-string": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.slurm.injection",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.slurm.injection"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.slurm.injection"
            }
          },
          "patterns": [
            {
              "include": "#escape-sequence"
            },
            {
              "match": "[^\"\\\\]+"
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.slurm.injection",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.slurm.injection"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.slurm.injection"
            }
          },
          "patterns": [
            {
              "include": "#escape-sequence"
            },
            {
              "match": "[^'\\\\]+"
            }
          ]
        }
      ]
    },
    "value-content": {
      "patterns": [
        {
          "include": "#quoted-string"
        },
        {
          "include": "#time-value"
        },
        {
          "include": "#numeric-value"
        },
        {
          "match": "[^\\s#\\\\\"']+",
          "name": "variable.parameter.slurm.injection"
        },
        {
          "include": "#escape-sequence"
        }
      ]
    },
    "time-value": {
      "match": "(?:\\d+-)?\\d+:[0-5]?\\d:[0-5]?\\d(?=\\s|$)",
      "name": "variable.other.constant.time.slurm.injection"
    },
    "numeric-value": {
      "match": "(?<=\\s|=|(-[a-zA-Z]))\\d+(?=\\s|$)",
      "name": "constant.numeric.slurm.injection"
    }
  }
}